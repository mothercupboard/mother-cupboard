{
    "cli":  {
                "version":  "\u003e= 7.0.0"
            },
    "build":  {
                  "development":  {
                                      "developmentClient":  true,
                                      "distribution":  "internal",
                                      "environment":  "development",
                                      "ios":  {
                                                  "simulator":  true,
                                                  "image":  "latest"
                                              },
                                      "android":  {
                                                      "image":  "latest"
                                                  },
                                      "env":  {
                                                  "EXPO_PUBLIC_APP_ENV":  "development"
                                              }
                                  },
                  "preview":  {
                                  "channel":  "preview",
                                  "distribution":  "internal",
                                  "ios":  {
                                              "image":  "latest"
                                          },
                                  "android":  {
                                                  "buildType":  "apk",
                                                  "image":  "latest"
                                              },
                                  "environment":  "preview",
                                  "env":  {
                                              "EXPO_PUBLIC_APP_ENV":  "preview"
                                          }
                              },
                  "production":  {
                                     "channel":  "production",
                                     "autoIncrement":  true,
                                     "distribution":  "store",
                                     "environment":  "production",
                                     "ios":  {
                                                 "image":  "latest"
                                             },
                                     "android":  {
                                                     "buildType":  "app-bundle",
                                                     "image":  "latest"
                                                 },
                                     "env":  {
                                                 "EXPO_PUBLIC_APP_ENV":  "production"
                                             }
                                 }
              },
    "submit":  {
                   "production":  {
                                      "ios":  {
                                                  "appleId":  "PLACEHOLDER"
                                              },
                                      "android":  {
                                                      "serviceAccountKeyPath":  "PLACEHOLDER"
                                                  }
                                  }
               }
}
